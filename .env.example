# Required to actually send form submissions (Join, Opportunity, Newcomer
# Intake, Mentor Request, Business Listing) to info@togorising.org.
# Sign up free at https://resend.com, create an API key, and paste it below.
# Without this set, forms will show a friendly "email us directly" fallback
# instead of failing silently.
RESEND_API_KEY=

# Optional: override the "from" address once you've verified a sending
# domain in Resend. Defaults to Resend's shared test sender, which works
# out of the box but is best swapped for your own domain before real use.
RESEND_FROM_EMAIL="Togo Rising <onboarding@resend.dev>"
